# PostgreSQL (matches docker-compose.yml)
DATABASE_URL="postgresql://exori:exori@localhost:5433/exori_nextjs"

# Auth.js — generate with: openssl rand -base64 32
AUTH_SECRET=""

# Default admin seeded on first `npm run db:seed`
SEED_ADMIN_EMAIL="admin@exori.local"
SEED_ADMIN_PASSWORD="changeme"
SEED_ADMIN_NAME="Exori Admin"

# Stripe — https://dashboard.stripe.com/test/apikeys
STRIPE_SECRET_KEY=""
STRIPE_PUBLISHABLE_KEY=""
STRIPE_WEBHOOK_SECRET=""

# Public site URL (used for Stripe redirect URLs)
NEXT_PUBLIC_BASE_URL="http://localhost:3000"
